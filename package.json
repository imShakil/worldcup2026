{
  "name": "worldcup2026-api",
  "version": "1.0.5",
  "description": "Free open-source REST API for FIFA World Cup 2026 — live scores, match schedule, group standings, 48 teams, 16 stadiums. Real-time updates during the tournament.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "set NODE_ENV=development&& nodemon index.js",
    "prod": "set NODE_ENV=production&& node index.js",
    "start:dev": "cross-env NODE_ENV=development nodemon index.js",
    "start:prod": "cross-env NODE_ENV=production node index.js",
    "import:all": "node scripts/import-groups.js && node scripts/import-teams.js && node scripts/import-stadiums.js && node scripts/import-matches.js",
    "import:groups": "node scripts/import-groups.js",
    "import:teams": "node scripts/import-teams.js",
    "import:stadiums": "node scripts/import-stadiums.js",
    "import:matches": "node scripts/import-matches.js",
    "import:games": "node scripts/import-games.js",
    "test:load": "node load-test.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:start:prod": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:logs:api": "pm2 logs wc-api",
    "pm2:logs:updater": "pm2 logs wc-updater",
    "pm2:save": "pm2 save",
    "pm2:setup": "pm2 startup"
  },
  "keywords": [
    "fifa-world-cup-2026",
    "world-cup-api",
    "football-api",
    "soccer-api",
    "free-api",
    "free-football-api",
    "free-soccer-api",
    "free-sports-api",
    "live-scores",
    "live-score-api",
    "live-results",
    "rest-api",
    "express",
    "node",
    "mongodb",
    "swagger",
    "openapi",
    "jwt-authentication",
    "real-time-scores",
    "sports-api",
    "sports-data",
    "48-teams",
    "usa-mexico-canada",
    "world-cup-schedule",
    "world-cup-fixtures",
    "world-cup-standings",
    "world-cup-groups",
    "football-data",
    "soccer-data",
    "open-source"
  ],
  "author": "jp2435",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.17.2",
    "express-rate-limit": "^8.2.1",
    "fs": "0.0.1-security",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.2.5",
    "morgan": "^1.10.0",
    "path": "^0.12.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^2.0.15"
  }
}
